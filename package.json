{
  "name": "@ticktick/ticktick-cli",
  "version": "0.1.1",
  "description": "Command-line interface for TickTick",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ticktick": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "keywords": [
    "ticktick",
    "cli",
    "todo",
    "tasks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TickTeam/ticktick-cli.git"
  },
  "homepage": "https://github.com/TickTeam/ticktick-cli#readme",
  "bugs": "https://github.com/TickTeam/ticktick-cli/issues",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "yocto-spinner": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
